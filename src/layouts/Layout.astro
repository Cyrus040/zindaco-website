---
import { SITE, BRAND, NAV_LINKS, LEGAL_LINKS } from '../site.config.ts';

const { title, description } = Astro.props;
const pageTitle = title ? `${title} | ${SITE.name}` : SITE.name;
const pageDesc = description || SITE.tagline;
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <meta name="theme-color" content={BRAND.primary} />

    <!-- System font stack (DSGVO-konform, kein Google Fonts) -->
    <style is:global>
      :root {
        --brand: #C8822A;
        --brand-light: #E8A84A;
        --brand-dark: #A6661A;
        --text: #FFFFFF;
        --bg: #1A1A1A;
        --bg-card: #2a2a2a;
        --bg-hover: #333333;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Helvetica Neue', Arial, sans-serif;
        background-color: var(--bg);
        color: var(--text);
        line-height: 1.6;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      main { flex: 1; }
      a { color: var(--brand); text-decoration: none; transition: color 0.2s; }
      a:hover { color: var(--brand-light); }
      h1, h2, h3, h4 { line-height: 1.2; font-weight: 700; }
      h1 { font-size: clamp(2rem, 5vw, 3.5rem); }
      h2 { font-size: clamp(1.5rem, 3vw, 2.5rem); margin-bottom: 1rem; }
      h3 { font-size: clamp(1.2rem, 2vw, 1.5rem); margin-bottom: 0.75rem; }
      p { margin-bottom: 1rem; }
      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
      }
      .btn {
        display: inline-block;
        padding: 0.75rem 2rem;
        background: var(--brand);
        color: #fff;
        border-radius: 0.375rem;
        font-weight: 600;
        transition: background 0.2s, transform 0.1s;
        border: none;
        cursor: pointer;
      }
      .btn:hover {
        background: var(--brand-light);
        color: #fff;
        transform: translateY(-1px);
      }
      .btn-outline {
        background: transparent;
        border: 2px solid var(--brand);
        color: var(--brand);
      }
      .btn-outline:hover {
        background: var(--brand);
        color: #fff;
      }
      .section { padding: 5rem 0; }
      .section-dark { background: var(--bg-card); }
      img { max-width: 100%; height: auto; }
      .text-brand { color: var(--brand); }
      .text-center { text-align: center; }
      .mt-4 { margin-top: 1rem; }
      .mt-8 { margin-top: 2rem; }
      .mb-4 { margin-bottom: 1rem; }
      .mb-8 { margin-bottom: 2rem; }
      .gap-4 { gap: 1rem; }
      .gap-8 { gap: 2rem; }
      .flex { display: flex; }
      .flex-col { flex-direction: column; }
      .items-center { align-items: center; }
      .justify-center { justify-content: center; }
      .justify-between { justify-content: space-between; }
      .flex-wrap { flex-wrap: wrap; }
      .grid { display: grid; gap: 2rem; }
      .grid-3 { grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); }
      .card {
        background: var(--bg-card);
        border-radius: 0.75rem;
        padding: 2rem;
        border: 1px solid rgba(255,255,255,0.05);
        transition: border-color 0.2s, transform 0.2s;
      }
      .card:hover {
        border-color: var(--brand);
        transform: translateY(-2px);
      }
      @media (max-width: 768px) {
        .section { padding: 3rem 0; }
      }
    </style>
  </head>
  <body>
    <!-- Navigation -->
    <header style="background: rgba(26,26,26,0.95); backdrop-filter: blur(10px); border-bottom: 1px solid rgba(255,255,255,0.05); position: sticky; top: 0; z-index: 50;">
      <nav class="container" style="display: flex; justify-content: space-between; align-items: center; padding: 1rem 1.5rem;">
        <a href="/" style="font-size: 1.5rem; font-weight: 700; color: var(--brand); text-decoration: none;">
          {SITE.shortName}
        </a>
        <ul style="display: flex; gap: 2rem; list-style: none;">
          {NAV_LINKS.map(link => (
            <li>
              <a href={link.href} style="color: var(--text); font-weight: 500; font-size: 0.95rem; padding: 0.5rem 0; transition: color 0.2s;">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </header>

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer style="background: #111; border-top: 1px solid rgba(255,255,255,0.05); padding: 3rem 0 1.5rem;">
      <div class="container">
        <div class="grid grid-3" style="margin-bottom: 2rem;">
          <div>
            <h4 style="color: var(--brand); margin-bottom: 1rem;">{SITE.shortName}</h4>
            <p style="font-size: 0.9rem; color: #999;">
              KI-gestützte Automatisierung für Ihren Unternehmenserfolg.
            </p>
          </div>
          <div>
            <h4 style="color: var(--brand); margin-bottom: 1rem;">Navigation</h4>
            <ul style="list-style: none; font-size: 0.9rem;">
              {NAV_LINKS.map(link => (
                <li style="margin-bottom: 0.5rem;">
                  <a href={link.href} style="color: #999;">{link.label}</a>
                </li>
              ))}
            </ul>
          </div>
          <div>
            <h4 style="color: var(--brand); margin-bottom: 1rem;">Kontakt</h4>
            <p style="font-size: 0.9rem; color: #999;">
              {SITE.address.street}<br />
              {SITE.address.city}<br />
              <a href={`mailto:${SITE.email}`} style="color: var(--brand);">{SITE.email}</a>
            </p>
          </div>
        </div>
        <div style="border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1.5rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
          <p style="font-size: 0.85rem; color: #666;">
            &copy; {new Date().getFullYear()} {SITE.name}. Alle Rechte vorbehalten.
          </p>
          <ul style="display: flex; gap: 1.5rem; list-style: none; font-size: 0.85rem;">
            {LEGAL_LINKS.map(link => (
              <li>
                <a href={link.href} style="color: #666;">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </footer>
  </body>
</html>
